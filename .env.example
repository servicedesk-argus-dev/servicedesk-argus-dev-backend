# Argus backend environment template.
# Keep real values in Vault/Kubernetes secrets or a local untracked .env file.

ARGUS_ENV=development
APP_VERSION=v1.0.0
BUILD_COMMIT=local
BUILD_TIME=local
ARGUS_SECRETS_FILE=
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-dev-only-django-secret-key-32chars
JWT_SIGNING_KEY=change-me-dev-only-jwt-signing-key-32chars
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_PROXY_IPS=

# Database: set either DATABASE_URL or the DB_* fields.
DATABASE_URL=
DB_ENGINE=django.db.backends.postgresql
DB_NAME=argus_servicedesk
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=

# Redis / Celery / realtime Socket.IO.
REDIS_URL=redis://127.0.0.1:6379/0
SOCKETIO_REDIS_URL=

# Keycloak SSO.
KEYCLOAK_ENABLED=true
KEYCLOAK_ISSUER=http://localhost:8082/realms/ArgusService%20Desk
KEYCLOAK_JWKS_URL=
KEYCLOAK_ALLOWED_CLIENTS=argus-frontend,Argus-Frontend
KEYCLOAK_RBAC_CLIENTS=Argus-Frontend,Argus-Backend
KEYCLOAK_AUTO_CREATE_USERS=true
KEYCLOAK_DEFAULT_CLIENT_ORG=
KEYCLOAK_SYNC_LOCAL_ROLES=true
KEYCLOAK_PASSWORD_LOGIN_ENABLED=false
KEYCLOAK_PASSWORD_GRANT_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_TOKEN_URL=
KEYCLOAK_TOKEN_TIMEOUT=10

# LinkedEye / external alert webhook.
ARGUS_WEBHOOK_REQUIRE_TOKEN=false
ARGUS_WEBHOOK_API_TOKEN=
ARGUS_WEBHOOK_SYSTEM_USER_EMAIL=linkedeye.webhook@argus.local
ARGUS_WEBHOOK_DEFAULT_ORG_SLUG=

# Email.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Argus Service Desk <noreply@argus.io>

# Monitoring/bootstrap integrations.
ALERTMANAGER_URL=
PROMETHEUS_FILE_SD_PATH=/etc/prometheus/file_sd
ARGUS_DEFAULT_PROMETHEUS_URL=
ARGUS_DEFAULT_GRAFANA_URL=
ARGUS_DEFAULT_REDIS_URL=
ARGUS_DEFAULT_ENTITY_HOST=
ARGUS_DEFAULT_ENTITY_PORT=
